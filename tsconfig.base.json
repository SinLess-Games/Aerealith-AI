{
  "compilerOptions": {
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,

    "customConditions": ["Aerealith", "aerealith"],

    "paths": {
      "@aerealith-ai/ui": ["./libs/ui/src/index.ts"],
      "@aerealith-ai/ui/*": ["./libs/ui/src/*"],

      "@aerealith-ai/config": ["./libs/config/src/index.ts"],
      "@aerealith-ai/config/*": ["./libs/config/src/*"],

      "@aerealith-ai/db": ["./libs/db/src/index.ts"],
      "@aerealith-ai/db/*": ["./libs/db/src/*"],

      "@aerealith-ai/flags": ["./libs/flags/src/index.ts"],
      "@aerealith-ai/flags/*": ["./libs/flags/src/*"]
    }
  }
}
