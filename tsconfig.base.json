{
  "compilerOptions": {
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,

    "customConditions": ["Helix"],
    "paths": {
      "@helix-ai/ui/*": ["./libs/ui/src/*"],
      "@helix-ai/ui": ["./libs/ui/src/index.ts"],
      "@helix-ai/config/*": ["./libs/config/src/*"],
      "@helix-ai/config": ["./libs/config/src/index.ts"],
      "@helix-ai/db/*": ["./libs/db/src/*"],
      "@helix-ai/db": ["./libs/db/src/index.ts"],
      "@helix-ai/flags/*": ["./libs/flags/src/*"],
      "@helix-ai/flags": ["./libs/flags/src/index.ts"]
    }
  }
}