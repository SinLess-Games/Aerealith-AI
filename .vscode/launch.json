{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Debug auth with Nx",
      "command": "pnpm exec nx serve auth",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "NODE_ENV": "development",
        "NODE_OPTIONS": "--inspect=9229 --enable-source-maps",
        "FORCE_COLOR": "1"
      }
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Debug user with Nx",
      "command": "pnpm exec nx serve user",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "NODE_ENV": "development",
        "NODE_OPTIONS": "--inspect=9230 --enable-source-maps",
        "FORCE_COLOR": "1"
      }
    }
  ],
  "compounds": [
    {
      "name": "Debug auth + user with Nx",
      "configurations": [
        "Debug auth with Nx",
        "Debug user with Nx"
      ],
      "stopAll": true
    }
  ]
}