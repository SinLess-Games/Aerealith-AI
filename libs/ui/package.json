    "next": ">=16",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@grafana/faro-react": {
      "optional": true
    },
    "@grafana/faro-web-sdk": {
      "optional": true
    },
    "@grafana/faro-web-tracing": {
      "optional": true
    }
  },
  "dependencies": {
