{
  "name": "@aerealith-ai/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepublishOnly": "pnpm build"
