{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "flags",
  "projectType": "library",
  "sourceRoot": "libs/flags/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/libs/flags"
      ],
      "options": {
        "command": "tsc -p libs/flags/tsconfig.lib.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "tsc -p libs/flags/tsconfig.lib.json --noEmit"
      }
    }
  },
  "tags": [
    "scope:shared",
    "type:feature-flags"
  ]
}
