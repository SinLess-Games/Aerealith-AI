{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@aerealith-ai/flags",
  "projectType": "library",
  "sourceRoot": "libs/flags/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/libs/flags"
      ],
      "options": {
        "command": "tsc -p libs/flags/tsconfig.lib.json"
      }
    },

    "build.watch": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "tsc -p libs/flags/tsconfig.lib.json --watch"
      }
    },

    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "tsc -p libs/flags/tsconfig.lib.json --noEmit"
      }
    },

    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "eslint libs/flags --ext .ts"
      }
    }
  },
  "tags": [
    "scope:shared",
    "type:feature-flags",
    "runtime:isomorphic"
  ]
}