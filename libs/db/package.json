{
  "name": "@helix-ai/db",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "**/*"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "dependencies": {
    "@helix-ai/config": "workspace:*",
    "@mikro-orm/core": "^6.5.9",
    "@mikro-orm/migrations": "6.6.14",
    "@mikro-orm/postgresql": "^6.5.9",
    "uuid": "^13.0.0"
  }
}
