{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "importHelpers": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "composite": true,
    "paths": {
      "@aerealith-ai/db": [
        "../../dist/libs/db/index.d.ts"
      ],
      "@aerealith-ai/db/*": [
        "../../dist/libs/db/*"
      ],
      "@aerealith-ai/db/enums": [
        "../../dist/libs/db/enums/index.d.ts"
      ],
      "@aerealith-ai/ui": [
        "../../dist/libs/ui/index.d.ts"
      ],
      "@aerealith-ai/ui/*": [
        "../../dist/libs/ui/*"
      ]
    }
  },
  "files": [],
  "include": [],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
