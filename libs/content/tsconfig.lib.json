{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "../../dist/libs/content",
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "declaration": true,
    "composite": true,
    "tsBuildInfoFile": "../../dist/libs/content/tsconfig.lib.tsbuildinfo",
    "types": [
      "node"
    ],
    "disableSourceOfProjectReferenceRedirect": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "references": [
    {
      "path": "../db/tsconfig.lib.json"
    },
    {
      "path": "../ui/tsconfig.lib.json"
    }
  ],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ]
}
