{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",

  description:
    "Aerealith AI Renovate configuration for pnpm, Nx, GitHub Actions, Docker, Cloudflare tooling, and future Helm/Kubernetes self-hosted Helix deployment support.",

  enabled: true,

  baseBranchPatterns: ["main"],

  timezone: "America/Boise",

  extends: [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitType(chore)",
    ":semanticCommitScope(deps)",
    ":maintainLockFilesMonthly",
    ":prHourlyLimit2",
  ],

  enabledManagers: [
    "npm",
    "dockerfile",
    "github-actions",

    // Future self-hosted deployment support.
    "helmv3",
    "helm-values",
    "helmfile",
    "kubernetes",
    "kustomize",
  ],

  schedule: [
    "after 5pm every weekday",
    "every weekend",
  ],

  prHourlyLimit: 2,
  prConcurrentLimit: 10,
  branchConcurrentLimit: 10,

  dependencyDashboard: true,
  dependencyDashboardTitle: "Dependency Dashboard",
  dependencyDashboardLabels: [
    "dependencies",
    "repo-management",
    "no-release",
  ],

  labels: [
    "dependencies",
    "no-release",
  ],

  addLabels: [
    "status:ready",
  ],

  assigneesFromCodeOwners: true,
  reviewersFromCodeOwners: true,

  rebaseWhen: "behind-base-branch",

  automerge: false,
  automergeStrategy: "merge-commit",
  platformAutomerge: true,

  rangeStrategy: "bump",

  commitMessagePrefix: "chore(deps):",
  commitMessageAction: "update",
  commitMessageTopic: "{{depName}}",
  commitMessageExtra: "to {{newVersion}}",

  lockFileMaintenance: {
    enabled: true,
    schedule: [
      "before 5am on monday",
    ],
    labels: [
      "dependencies",
      "no-release",
      "kind:chore",
      "status:ready",
    ],
    automerge: true,
    platformAutomerge: true,
  },

  ignorePaths: [
    "**/node_modules/**",
    "**/.next/**",
    "**/.open-next/**",
    "**/.wrangler/**",
    "**/dist/**",
    "**/out/**",
    "**/build/**",
    "**/coverage/**",
    "**/.cache/**",
    "**/.nx/**",
    "**/tmp/**",
    "**/.turbo/**",
    "**/.vercel/**",
    "**/.netlify/**",
  ],

  npm: {
    managerFilePatterns: [
      "/(^|/)package\\.json$/",
      "/(^|/)pnpm-workspace\\.ya?ml$/",
      "/(^|/)pnpm-lock\\.yaml$/",
      "/(^|/)\\.npmrc$/",
    ],
  },

  dockerfile: {
    managerFilePatterns: [
      "/(^|/)Dockerfile$/",
      "/(^|/)Dockerfile\\.[^/]+$/",
      "/(^|/)docker/.+Dockerfile$/",
      "/(^|/)apps/.+/Dockerfile$/",
      "/(^|/)apps/.+/Dockerfile\\.[^/]+$/",
      "/(^|/)libs/.+/Dockerfile$/",
      "/(^|/)libs/.+/Dockerfile\\.[^/]+$/",
    ],
  },

  "github-actions": {
    managerFilePatterns: [
      "/(^|/)\\.github/workflows/.+\\.ya?ml$/",
      "/(^|/)\\.github/actions/.+/action\\.ya?ml$/",
    ],
  },

  helmv3: {
    managerFilePatterns: [
      "/(^|/)charts/.+/Chart\\.ya?ml$/",
      "/(^|/)deploy/.+/Chart\\.ya?ml$/",
      "/(^|/)helm/.+/Chart\\.ya?ml$/",
    ],
  },

  "helm-values": {
    managerFilePatterns: [
      "/(^|/)charts/.+/values\\.ya?ml$/",
      "/(^|/)charts/.+/values-.+\\.ya?ml$/",
      "/(^|/)deploy/.+/values\\.ya?ml$/",
      "/(^|/)deploy/.+/values-.+\\.ya?ml$/",
      "/(^|/)helm/.+/values\\.ya?ml$/",
      "/(^|/)helm/.+/values-.+\\.ya?ml$/",
    ],
  },

  helmfile: {
    managerFilePatterns: [
      "/(^|/)helmfile\\.ya?ml$/",
      "/(^|/)helmfile.d/.+\\.ya?ml$/",
      "/(^|/)deploy/.+/helmfile\\.ya?ml$/",
    ],
  },

  kubernetes: {
    managerFilePatterns: [
      "/(^|/)k8s/.+\\.ya?ml$/",
      "/(^|/)kubernetes/.+\\.ya?ml$/",
      "/(^|/)deploy/kubernetes/.+\\.ya?ml$/",
      "/(^|/)deploy/manifests/.+\\.ya?ml$/",
      "/(^|/)charts/.+/templates/.+\\.ya?ml$/",
    ],
  },

  kustomize: {
    managerFilePatterns: [
      "/(^|/)kustomization\\.ya?ml$/",
      "/(^|/)k8s/.+/kustomization\\.ya?ml$/",
      "/(^|/)kubernetes/.+/kustomization\\.ya?ml$/",
      "/(^|/)deploy/.+/kustomization\\.ya?ml$/",
    ],
  },

  packageRules: [
    // -------------------------------------------------------------------------
    // Global dependency PR behavior
    // -------------------------------------------------------------------------
    {
      description: "Mark every Renovate PR as dependency work and prevent release workflows.",
      matchManagers: [
        "npm",
        "dockerfile",
        "github-actions",
        "helmv3",
        "helm-values",
        "helmfile",
        "kubernetes",
        "kustomize",
      ],
      addLabels: [
        "dependencies",
        "no-release",
        "automation:renovate",
      ],
    },

    {
      description: "Automerge safe patch updates after branch protection and required checks pass.",
      matchUpdateTypes: ["patch"],
      addLabels: [
        "kind:chore",
        "priority:low",
        "status:ready",
      ],
      automerge: true,
      platformAutomerge: true,
      minimumReleaseAge: "3 days",
    },

    {
      description: "Automerge safe minor updates after branch protection and required checks pass.",
      matchUpdateTypes: ["minor"],
      addLabels: [
        "kind:chore",
        "priority:medium",
        "status:ready",
      ],
      automerge: true,
      platformAutomerge: true,
      minimumReleaseAge: "5 days",
    },

    {
      description: "Require manual review for all major updates.",
      matchUpdateTypes: ["major"],
      addLabels: [
        "kind:chore",
        "priority:high",
        "status:needs-review",
      ],
      dependencyDashboardApproval: true,
      automerge: false,
      minimumReleaseAge: "7 days",
    },

    {
      description: "Automerge security vulnerability fixes after strict CI and security checks pass.",
      matchVulnerabilityAlerts: true,
      addLabels: [
        "kind:security",
        "security:dependency",
        "area:security",
        "priority:critical",
        "status:ready",
      ],
      dependencyDashboardApproval: false,
      automerge: true,
      platformAutomerge: true,
      minimumReleaseAge: "0 days",
    },

    // -------------------------------------------------------------------------
    // Workspace package protection
    // -------------------------------------------------------------------------
    {
      description: "Do not update local Aerealith workspace package references.",
      matchManagers: ["npm"],
      matchPackageNames: [
        "/^@aerealith-ai\\//",
      ],
      enabled: false,
    },

    {
      description: "Do not update legacy local Helix workspace package references.",
      matchManagers: ["npm"],
      matchPackageNames: [
        "/^@helix-ai\\//",
      ],
      enabled: false,
    },

    // -------------------------------------------------------------------------
    // Monorepo path labels
    // -------------------------------------------------------------------------
    {
      description: "Label frontend dependency updates.",
      matchFileNames: [
        "apps/frontend/**",
      ],
      addLabels: [
        "area:frontend",
      ],
    },

    {
      description: "Label connector dependency updates.",
      matchFileNames: [
        "apps/connectors/**",
      ],
      addLabels: [
        "area:connectors",
      ],
    },

    {
      description: "Label engine dependency updates.",
      matchFileNames: [
        "apps/engines/**",
      ],
      addLabels: [
        "area:engines",
      ],
    },

    {
      description: "Label integration dependency updates.",
      matchFileNames: [
        "apps/integrations/**",
      ],
      addLabels: [
        "area:integrations",
      ],
    },

    {
      description: "Label service dependency updates.",
      matchFileNames: [
        "apps/services/**",
      ],
      addLabels: [
        "area:services",
      ],
    },

    {
      description: "Label e2e dependency updates.",
      matchFileNames: [
        "apps/e2e/**",
      ],
      addLabels: [
        "area:e2e",
        "kind:test",
      ],
    },

    {
      description: "Label library dependency updates.",
      matchFileNames: [
        "libs/**",
      ],
      addLabels: [
        "area:libs",
      ],
    },

    // -------------------------------------------------------------------------
    // npm / pnpm package groups
    // -------------------------------------------------------------------------
    {
      description: "Group npm and pnpm patch dependencies.",
      matchManagers: ["npm"],
      matchUpdateTypes: ["patch"],
      matchDepTypes: [
        "dependencies",
        "devDependencies",
        "optionalDependencies",
        "peerDependencies",
      ],
      groupName: "npm patch dependencies",
      addLabels: [
        "area:dependencies",
      ],
    },

    {
      description: "Group npm and pnpm minor dependencies.",
      matchManagers: ["npm"],
      matchUpdateTypes: ["minor"],
      matchDepTypes: [
        "dependencies",
        "devDependencies",
        "optionalDependencies",
        "peerDependencies",
      ],
      groupName: "npm minor dependencies",
      addLabels: [
        "area:dependencies",
      ],
    },

    {
      description: "Group npm and pnpm major dependencies for manual review.",
      matchManagers: ["npm"],
      matchUpdateTypes: ["major"],
      groupName: "npm major dependencies",
      addLabels: [
        "area:dependencies",
        "status:needs-review",
      ],
      dependencyDashboardApproval: true,
      automerge: false,
    },

    {
      description: "Group Next.js, React, and frontend framework updates for manual review.",
      matchManagers: ["npm"],
      matchPackageNames: [
        "next",
        "react",
        "react-dom",
        "@next/**",
        "@mui/**",
        "@emotion/**",
      ],
      groupName: "frontend framework dependencies",
      addLabels: [
        "area:frontend",
        "area:ui",
        "priority:high",
        "status:needs-review",
      ],
      automerge: false,
      dependencyDashboardApproval: true,
    },

    {
      description: "Group Nx workspace tooling updates for manual review.",
      matchManagers: ["npm"],
      matchPackageNames: [
        "nx",
        "@nx/**",
      ],
      groupName: "nx workspace dependencies",
      addLabels: [
        "area:ci",
        "kind:chore",
        "priority:high",
        "status:needs-review",
      ],
      automerge: false,
      dependencyDashboardApproval: true,
    },

    {
      description: "Group TypeScript, ESLint, Prettier, Jest, Vitest, Cypress, Playwright, and test tooling updates.",
      matchManagers: ["npm"],
      matchPackageNames: [
        "typescript",
        "eslint",
        "@eslint/**",
        "typescript-eslint",
        "@typescript-eslint/**",
        "prettier",
        "jest",
        "@jest/**",
        "ts-jest",
        "vitest",
        "@vitest/**",
        "playwright",
        "@playwright/**",
        "cypress",
        "@cypress/**",
      ],
      groupName: "lint test and typescript tooling",
      addLabels: [
        "area:ci",
        "kind:test",
        "priority:medium",
      ],
      automerge: false,
    },

    {
      description: "Group Cloudflare, Wrangler, Workers, and OpenNext updates for manual review.",
      matchManagers: ["npm"],
      matchPackageNames: [
        "wrangler",
        "@cloudflare/**",
        "@cloudflare/workers-types",
        "@opennextjs/cloudflare",
      ],
      groupName: "cloudflare deployment dependencies",
      addLabels: [
        "area:cloudflare",
        "cloudflare",
        "deployment",
        "priority:high",
        "status:needs-review",
      ],
      automerge: false,
      dependencyDashboardApproval: true,
    },

    {
      description: "Group OpenAI and AI automation dependencies for manual review.",
      matchManagers: ["npm"],
      matchPackageNames: [
        "openai",
        "@ai-sdk/**",
        "ai",
      ],
      groupName: "ai automation dependencies",
      addLabels: [
        "area:ai",
        "automation:openai",
        "priority:high",
        "status:needs-review",
      ],
      automerge: false,
      dependencyDashboardApproval: true,
    },

    {
      description: "Group GitHub API and workflow scripting dependencies.",
      matchManagers: ["npm"],
      matchPackageNames: [
        "@actions/**",
        "@octokit/**",
        "octokit",
        "js-yaml",
        "zod",
        "glob",
        "minimatch",
        "semver",
      ],
      groupName: "github automation script dependencies",
      addLabels: [
        "area:github-actions",
        "area:repo-management",
        "automation",
        "priority:medium",
      ],
      automerge: false,
    },

    {
      description: "Group database, ORM, and driver updates for manual review.",
      matchManagers: ["npm"],
      matchPackageNames: [
        "@mikro-orm/**",
        "pg",
        "postgres",
        "uuid",
        "drizzle-orm",
        "@neondatabase/**",
      ],
      groupName: "database dependencies",
      addLabels: [
        "area:db",
        "priority:high",
        "status:needs-review",
      ],
      automerge: false,
      dependencyDashboardApproval: true,
    },

    // -------------------------------------------------------------------------
    // GitHub Actions
    // -------------------------------------------------------------------------
    {
      description: "Group GitHub Actions updates.",
      matchManagers: ["github-actions"],
      groupName: "github actions dependencies",
      addLabels: [
        "actions-update",
        "area:github-actions",
        "area:ci",
        "automation",
      ],
      automerge: false,
    },

    {
      description: "Automerge patch-level GitHub Actions updates after checks pass.",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["patch"],
      addLabels: [
        "actions-update",
        "area:github-actions",
        "area:ci",
        "automation",
        "priority:low",
      ],
      automerge: true,
      platformAutomerge: true,
      minimumReleaseAge: "3 days",
    },

    {
      description: "Automerge minor GitHub Actions updates after checks pass.",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["minor"],
      addLabels: [
        "actions-update",
        "area:github-actions",
        "area:ci",
        "automation",
        "priority:medium",
      ],
      automerge: true,
      platformAutomerge: true,
      minimumReleaseAge: "5 days",
    },

    {
      description: "Require manual review for major GitHub Actions updates.",
      matchManagers: ["github-actions"],
      matchUpdateTypes: ["major"],
      addLabels: [
        "actions-update",
        "area:github-actions",
        "area:ci",
        "automation",
        "priority:high",
        "status:needs-review",
      ],
      automerge: false,
      dependencyDashboardApproval: true,
    },

    // -------------------------------------------------------------------------
    // Docker
    // -------------------------------------------------------------------------
    {
      description: "Group Dockerfile image updates.",
      matchManagers: ["dockerfile"],
      groupName: "docker image dependencies",
      addLabels: [
        "deployment",
        "area:docker",
        "area:ci",
        "priority:medium",
      ],
      automerge: false,
    },

    {
      description: "Automerge Docker patch updates after image build and security checks pass.",
      matchManagers: ["dockerfile"],
      matchUpdateTypes: ["patch"],
      addLabels: [
        "deployment",
        "area:docker",
        "priority:low",
      ],
      automerge: true,
      platformAutomerge: true,
      minimumReleaseAge: "3 days",
    },

    // -------------------------------------------------------------------------
    // Future Helm / Kubernetes self-hosted support
    // -------------------------------------------------------------------------
    {
      description: "Group Helm chart dependency updates for self-hosted deployments.",
      matchManagers: [
        "helmv3",
        "helm-values",
        "helmfile",
      ],
      groupName: "helm self hosted deployment dependencies",
      addLabels: [
        "area:helm",
        "area:self-hosted",
        "deployment",
        "priority:high",
        "status:needs-review",
      ],
      automerge: false,
      dependencyDashboardApproval: true,
    },

    {
      description: "Group Kubernetes and Kustomize dependency updates for self-hosted deployments.",
      matchManagers: [
        "kubernetes",
        "kustomize",
      ],
      groupName: "kubernetes self hosted deployment dependencies",
      addLabels: [
        "area:kubernetes",
        "area:self-hosted",
        "deployment",
        "priority:high",
        "status:needs-review",
      ],
      automerge: false,
      dependencyDashboardApproval: true,
    },

    // -------------------------------------------------------------------------
    // Generated files
    // -------------------------------------------------------------------------
    {
      description: "Disable updates in generated or build-output package files.",
      matchFileNames: [
        "**/dist/**",
        "**/build/**",
        "**/.next/**",
        "**/.open-next/**",
        "**/.wrangler/**",
        "**/coverage/**",
        "**/.cache/**",
        "**/.nx/**",
      ],
      enabled: false,
    },
  ],
}