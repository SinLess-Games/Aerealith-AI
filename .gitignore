# ─────────────────────────────────────────────
# Helix / Nx Monorepo
# ─────────────────────────────────────────────

# Nx & build outputs
dist/
out/
.next/
tmp/
.cache/
build/
coverage/
reports/
test-output/

# Generated libs/assets
*.tsbuildinfo
*.log
*.pid
*.seed
*.tgz
*.swp

# Local runtime data
null

# ─────────────────────────────────────────────
# Node / pnpm
# ─────────────────────────────────────────────
node_modules/
.pnp.*
.pnpm-store/
.npm/
.yarn/
.yarnrc.yml
yarn-error.log

# Lockfiles
# Keep pnpm-lock.yaml committed.
package-lock.json
yarn.lock

# ─────────────────────────────────────────────
# Environment & secrets
# ─────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.sample
!.env.local.example
.npmrc.local

# ─────────────────────────────────────────────
# IDEs & editors
# ─────────────────────────────────────────────
.idea/
*.code-workspace
*.iml
*.ipr
*.iws
.idea_modules/
.vscode-test/

# Keep VS Code workspace settings if committed intentionally.
# Uncomment this if you want all local VS Code settings ignored.
# .vscode/

# ─────────────────────────────────────────────
# OS junk
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
*.tmp
*~
.trash/
.nfs*

# ─────────────────────────────────────────────
# Logs & diagnostics
# ─────────────────────────────────────────────
logs/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
lerna-debug.log*
*.stackdump

# ─────────────────────────────────────────────
# Docker & local containers
# ─────────────────────────────────────────────
.docker/
docker-compose.override.yml
*.tar
*.img
*.qcow2

# ─────────────────────────────────────────────
# Local development tooling
# ─────────────────────────────────────────────
.envrc
.direnv/
.local/
.secret/
.mitmproxy/

# ─────────────────────────────────────────────
# Nx specific
# ─────────────────────────────────────────────
.nx/

# Ignore generated files from Nx plugins
libs/**/src/generated/
apps/**/src/generated/

# ─────────────────────────────────────────────
# Vercel
# ─────────────────────────────────────────────
.vercel/

# ─────────────────────────────────────────────
# OpenNext / Cloudflare Workers
# ─────────────────────────────────────────────

# OpenNext output
.open-next/
apps/**/.open-next/

# Cloudflare local state
.wrangler/
apps/**/.wrangler/

# Cloudflare local env files
.dev.vars
.dev.vars.*
apps/**/.dev.vars
apps/**/.dev.vars.*

# Wrangler generated type output may be committed if wanted.
# Uncomment if you want it ignored instead.
# apps/**/cloudflare-env.d.ts

# ─────────────────────────────────────────────
# Project-specific generated files
# ─────────────────────────────────────────────
docker/hashicorp/certs/