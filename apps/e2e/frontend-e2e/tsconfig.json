{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "noEmit": true,
    "sourceMap": false,
    "types": ["cypress", "node"]
  },
  "include": [
    "cypress.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    "**/*.d.ts"
  ],
  "exclude": ["out-tsc", "test-output", "dist", "coverage"],
  "references": []
}
