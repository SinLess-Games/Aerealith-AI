{
  "name": "frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/frontend/src",
  "tags": [
    "npm:private"
  ],
  "implicitDependencies": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "^build",
        "generate-site-assets"
      ],
      "cache": true,
      "inputs": [
        "default",
        "^default",
        {
          "externalDependencies": [
            "next"
          ]
        }
      ],
      "outputs": [
        "{workspaceRoot}/dist/apps/frontend"
      ],
      "options": {
        "cwd": "apps/frontend",
        "tty": false,
        "command": "next build && node ./scripts/ensure-middleware-manifest.mjs"
      },
      "syncGenerators": [
        "@nx/js:typescript-sync"
      ],
      "parallelism": true,
      "configurations": {}
    },
    "generate-site-assets": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "default",
        "{workspaceRoot}/Docs/New_Branding/tokens/aerealith-brand-tokens.json",
        "{workspaceRoot}/libs/ui/src/theme/tokens/aerealith-brand-tokens.json",
        "{workspaceRoot}/apps/frontend/public/icons/*.png"
      ],
      "outputs": [
        "{workspaceRoot}/apps/frontend/public/site.webmanifest",
        "{workspaceRoot}/apps/frontend/public/site.xml"
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "node ./scripts/generate-site-assets.mjs"
      },
      "parallelism": false,
      "configurations": {}
    },
    "dev": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "cwd": "apps/frontend",
        "command": "next dev"
      },
      "syncGenerators": [
        "@nx/js:typescript-sync"
      ],
      "parallelism": true,
      "configurations": {},
      "dependsOn": [
        "@aerealith-ai/db:build",
        "@aerealith-ai/observability:sync-dist",
        "dev-services"
      ]
    },
    "dev-services": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "node apps/frontend/scripts/dev-services.mjs"
      },
      "parallelism": true,
      "configurations": {}
    },
    "start": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": [
        "build"
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "next start"
      },
      "configurations": {},
      "parallelism": true
    },
    "serve-static": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": [
        "build"
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "next start"
      },
      "configurations": {},
      "parallelism": true
    },
    "build-deps": {
      "executor": "nx:noop",
      "dependsOn": [
        "^build"
      ],
      "options": {},
      "configurations": {},
      "parallelism": true
    },
    "watch-deps": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": [
        "build-deps"
      ],
      "options": {
        "command": "pnpm exec nx watch --projects frontend --includeDependentProjects -- pnpm exec nx build-deps frontend"
      },
      "configurations": {},
      "parallelism": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/eslint.config.mjs",
        "{workspaceRoot}/apps/frontend/eslint.config.mjs",
        "{workspaceRoot}/tools/eslint-rules/**/*",
        {
          "externalDependencies": [
            "eslint"
          ]
        }
      ],
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "eslint --max-warnings=0 \"src/**/*.{js,jsx,ts,tsx}\" \"scripts/**/*.{js,mjs,cjs,ts,tsx}\" \"*.{js,mjs,cjs,ts,tsx}\""
      },
      "metadata": {
        "technologies": [
          "eslint"
        ],
        "description": "Runs ESLint on project",
        "help": {
          "command": "pnpm exec eslint --help",
          "example": {
            "options": {
              "max-warnings": 0
            }
          }
        }
      },
      "syncGenerators": [
        "@nx/js:typescript-sync"
      ],
      "configurations": {},
      "parallelism": true
    },
    "db:migrate": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/libs/db/src/**/*",
        {
          "externalDependencies": [
            "@mikro-orm/core",
            "@mikro-orm/migrations",
            "@mikro-orm/postgresql",
            "pg",
            "tsx"
          ]
        }
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "pnpm run db:migrate"
      },
      "configurations": {},
      "parallelism": false
    },
    "db:migration:up": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/libs/db/src/**/*",
        {
          "externalDependencies": [
            "@mikro-orm/core",
            "@mikro-orm/migrations",
            "@mikro-orm/postgresql",
            "pg",
            "tsx"
          ]
        }
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "pnpm run db:migration:up"
      },
      "configurations": {},
      "parallelism": false
    },
    "db:migration:down": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/libs/db/src/**/*",
        {
          "externalDependencies": [
            "@mikro-orm/core",
            "@mikro-orm/migrations",
            "@mikro-orm/postgresql",
            "pg",
            "tsx"
          ]
        }
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "pnpm run db:migration:down"
      },
      "configurations": {},
      "parallelism": false
    },
    "db:migration:create": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/libs/db/src/**/*",
        {
          "externalDependencies": [
            "@mikro-orm/core",
            "@mikro-orm/migrations",
            "@mikro-orm/postgresql",
            "pg",
            "tsx"
          ]
        }
      ],
      "outputs": [
        "{workspaceRoot}/libs/db/src/migrations"
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "pnpm run db:migration:create"
      },
      "configurations": {},
      "parallelism": false
    },
    "db:migration:list": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/libs/db/src/**/*",
        {
          "externalDependencies": [
            "@mikro-orm/core",
            "@mikro-orm/migrations",
            "@mikro-orm/postgresql",
            "pg",
            "tsx"
          ]
        }
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "pnpm run db:migration:list"
      },
      "configurations": {},
      "parallelism": false
    },
    "db:migration:pending": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/libs/db/src/**/*",
        {
          "externalDependencies": [
            "@mikro-orm/core",
            "@mikro-orm/migrations",
            "@mikro-orm/postgresql",
            "pg",
            "tsx"
          ]
        }
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "pnpm run db:migration:pending"
      },
      "configurations": {},
      "parallelism": false
    },
    "db:migration:check": {
      "executor": "nx:run-commands",
      "cache": false,
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/libs/db/src/**/*",
        {
          "externalDependencies": [
            "@mikro-orm/core",
            "@mikro-orm/migrations",
            "@mikro-orm/postgresql",
            "pg",
            "tsx"
          ]
        }
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "pnpm run db:migration:check"
      },
      "configurations": {},
      "parallelism": false
    },
    "cf:typegen": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "cloudflare"
      ],
      "outputs": [
        "{projectRoot}/cloudflare-env.d.ts"
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
      },
      "configurations": {},
      "parallelism": true
    },
    "cf:build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "^build"
      ],
      "cache": true,
      "inputs": [
        "production",
        "^production",
        "cloudflare",
        {
          "externalDependencies": [
            "next",
            "@opennextjs/cloudflare",
            "wrangler"
          ]
        }
      ],
      "outputs": [
        "{projectRoot}/.open-next"
      ],
      "options": {
        "cwd": "apps/frontend",
        "tty": false,
        "command": "NODE_ENV=production NEXT_PRIVATE_MINIMAL_MODE=1 opennextjs-cloudflare build"
      },
      "syncGenerators": [
        "@nx/js:typescript-sync"
      ],
      "configurations": {},
      "parallelism": true
    },
    "cf:preview": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": [
        "cf:build"
      ],
      "cache": false,
      "inputs": [
        "production",
        "^production",
        "cloudflare",
        {
          "externalDependencies": [
            "@opennextjs/cloudflare",
            "wrangler"
          ]
        }
      ],
      "options": {
        "cwd": "apps/frontend",
        "command": "opennextjs-cloudflare preview"
      },
      "configurations": {},
      "parallelism": true
    },
    "cf:deploy": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "cf:build"
      ],
      "cache": false,
      "inputs": [
        "production",
        "^production",
        "cloudflare",
        {
          "externalDependencies": [
            "@opennextjs/cloudflare",
            "wrangler"
          ]
        }
      ],
      "options": {
        "cwd": "apps/frontend",
        "tty": false,
        "command": "opennextjs-cloudflare deploy"
      },
      "configurations": {},
      "parallelism": true
    },
    "cf:upload": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "cf:build"
      ],
      "cache": false,
      "inputs": [
        "production",
        "^production",
        "cloudflare",
        {
          "externalDependencies": [
            "@opennextjs/cloudflare",
            "wrangler"
          ]
        }
      ],
      "options": {
        "cwd": "apps/frontend",
        "tty": false,
        "command": "opennextjs-cloudflare upload"
      },
      "configurations": {},
      "parallelism": true
    }
  }
}
