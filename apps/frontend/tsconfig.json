{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "lib": ["dom", "dom.iterable", "es2022"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "resolveJsonModule": true,
    "strict": true,
    "target": "es2022",
    "types": [
      "node"
    ]
  },
  "include": [
    "*.cts",
    "*.mts",
    "*.ts",
    "*.tsx",
    "next-env.d.ts",
    "src/**/*.cts",
    "src/**/*.mts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "coverage"
  ],
  "references": [
    {
      "path": "../../libs/ui"
    },
    {
      "path": "../../libs/flags"
    },
    {
      "path": "../../libs/db"
    },
    {
      "path": "../../libs/contracts"
    },
    {
      "path": "../../libs/content"
    },
    {
      "path": "../../libs/config"
    }
  ]
}
