{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "strict": false,
    "composite": false,
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "emitDeclarationOnly": false,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "target": "es2022",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,

    "types": [
      "node",
      "@cloudflare/workers-types"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "*.ts",
    "*.tsx",
    ".next/types/**/*.ts",
    "cloudflare-env.d.ts",
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../dist/apps/frontend/types/**/*.ts"
, "../../libs/ui/src/components/login-signup.ts"  ],
  "exclude": [
    "node_modules",
    ".next/cache",
    ".open-next",
    ".wrangler",
    "out-tsc",
    "dist",
    "../../dist",
    "../../dist/apps/frontend",
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "references": [
    {
      "path": "../../libs/config"
    },
    {
      "path": "../../libs/db"
    },
    {
      "path": "../../libs/flags"
    },
    {
      "path": "../../libs/ui"
    }
  ]
}