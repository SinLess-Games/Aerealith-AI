{
  "name": "aerealith-ai",
  "private": true,
  "version": "0.2.0",
  "description": "Aerealith AI — a secure, user-controlled digital companion and intelligent command center for users, creators, and businesses.",
  "main": "index.js",
  "scripts": {
    "graph": "nx graph",
    "graph:watch": "nx graph --watch",
    "grapgh": "pnpm graph",
    "start": "pnpm --filter frontend start",
    "dev": "pnpm --filter frontend dev",
    "preview": "pnpm --filter frontend preview",
    "build": "nx run-many --target=build --all --parallel=3",
    "deploy": "pnpm --filter frontend deploy",
    "upload": "pnpm --filter frontend upload",
    "cf:typegen": "pnpm --filter frontend cf:typegen",
    "wrangler:version": "wrangler --version",
    "wrangler:deploy": "pnpm --filter frontend deploy",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "lint": "nx run-many --target=lint --all --parallel=3",
    "test": "nx run-many --target=test --all --parallel=3",
    "typecheck": "nx run-many --target=typecheck --all --parallel=3",
    "e2e": "nx run-many --target=e2e --all --parallel=1",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test",
    "ci": "pnpm check && pnpm build",
    "affected": "nx affected --targets=lint,test,build",
    "affected:lint": "nx affected --target=lint",
    "affected:test": "nx affected --target=test",
    "affected:build": "nx affected --target=build",
    "affected:typecheck": "nx affected --target=typecheck",
    "affected:e2e": "nx affected --target=e2e --parallel=1",
    "cy:install": "cypress install",
    "cy:verify": "cypress verify",
    "commitlint": "commitlint --edit",
    "lint-staged": "lint-staged",
    "publish:libs": "pnpm -w -r publish --access public",
    "update:todo": "node .github/scripts/update-todo.mjs",
    "prepare": "husky"
  },
  "keywords": [
    "aerealith",
    "aerealith-ai",
    "ai",
    "assistant",
    "automation",
    "cloudflare",
    "workers",
    "nextjs",
    "nx",
    "hono",
    "nestjs",
    "digital-companion"
  ],
  "author": "SinLess Games LLC",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://aerealith.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SinLess-Games/Aerealith-AI.git"
  },
  "bugs": {
    "url": "https://github.com/SinLess-Games/Aerealith-AI/issues"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.23.0"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "overrides": {
      "next": "15.5.16"
    }
  },
  "lint-staged": {
    "*.{json,jsonc,md,mdx,yml,yaml,css,scss,html}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@babel/core": "^7.29.6",
    "@babel/preset-react": "^7.14.5",
    "@cloudflare/vitest-pool-workers": "^0.16.2",
    "@cloudflare/workers-types": "^4.20260507.1",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@eslint/compat": "^2.0.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.8.0",
    "@mikro-orm/cli": "6.6.14",
    "@mikro-orm/migrations": "6.6.14",
    "@naxodev/nx-cloudflare": "^5.0.2",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@next/eslint-plugin-next": "^16.0.0",
    "@nx/cypress": "22.1.3",
    "@nx/eslint": "22.1.3",
    "@nx/eslint-plugin": "22.1.3",
    "@nx/jest": "22.1.3",
    "@nx/js": "22.1.3",
    "@nx/nest": "22.1.3",
    "@nx/next": "22.1.3",
    "@nx/node": "22.1.3",
    "@nx/react": "22.1.3",
    "@nx/rollup": "22.1.3",
    "@nx/web": "22.1.3",
    "@nx/webpack": "22.1.3",
    "@opennextjs/cloudflare": "^1.19.8",
    "@rollup/plugin-url": "^8.0.2",
    "@svgr/rollup": "^8.1.0",
    "@swc-node/register": "~1.11.0",
    "@swc/cli": "~0.7.9",
    "@swc/core": "~1.15.1",
    "@swc/helpers": "~0.5.11",
    "@swc/jest": "~0.2.38",
    "@swc/plugin-emotion": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "24.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "core-js": "^3.36.1",
    "cypress": "^15.0.0",
    "eslint": "^9.8.0",
    "eslint-config-next": "^16.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^17.0.7",
    "nx": "22.1.3",
    "nx-mcp": "^0.10.0",
    "openai": "^6.9.1",
    "prettier": "^3.8.3",
    "rollup": "^4.53.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.2",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.48.0",
    "webpack-cli": "^6.0.1",
    "wrangler": "^4.90.0",
    "yaml": "^2.8.1"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/server": "11.11.0",
    "@emotion/styled": "11.14.1",
    "@hono/zod-validator": "^0.7.6",
    "@mikro-orm/core": "^6.6.1",
    "@mikro-orm/postgresql": "^6.6.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "axios": "^1.6.0",
    "hono": "^4.12.25",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^4.4.3"
  }
}
