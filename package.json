      "typescript": "5.9.3",
      "eslint": "9.39.4",
      "@eslint/js": "9.39.4",
      "@types/node": "24.10.1"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@swc/core",
      "core-js",
      "cypress",
      "esbuild",
      "less",
      "nx",
      "protobufjs",
