{
  "name": "helix",
  "private": true,
  "version": "0.2.0",
  "description": "Helix AI — autonomous assistant platform for users, creators, and businesses.",
  "main": "index.js",
  "scripts": {
    "graph": "nx graph --watch",
    "grapgh": "pnpm graph",
    "build": "pnpm -w -r build",
    "start": "pnpm --filter frontend start",
    "dev": "pnpm --filter frontend dev",
    "preview": "pnpm --filter frontend preview",
    "deploy": "pnpm --filter frontend deploy",
    "upload": "pnpm --filter frontend upload",
    "cf:typegen": "pnpm --filter frontend cf:typegen",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "lint": "nx run-many -t lint --all",
    "test": "nx run-many -t test --all",
    "typecheck": "nx run-many -t typecheck --all",
    "ci": "pnpm format:check && pnpm lint && pnpm test && pnpm build",
    "affected:lint": "nx affected -t lint",
    "affected:test": "nx affected -t test",
    "affected:build": "nx affected -t build",
    "affected": "nx affected -t lint test build",
    "publish:libs": "pnpm -w -r publish --access public",
    "update:todo": "node .github/scripts/update-todo.mjs"
  },
  "keywords": [
    "helix",
    "ai",
    "assistant",
    "automation",
    "cloudflare",
    "workers",
    "nextjs",
    "nx"
  ],
  "author": "SinLess Games LLC",
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "overrides": {
      "next": "15.5.16"
    }
  },
