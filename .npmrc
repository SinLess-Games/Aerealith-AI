# Workspace-wide npm configuration for Aerealith AI packages.
# Safe to commit. Do not hardcode npm tokens in this file.
#
# CI auth should come from the NPM_TOKEN / NODE_AUTH_TOKEN secret.
# Local auth should live in your user-level ~/.npmrc.

registry=https://registry.npmjs.org/
@aerealith-ai:registry=https://registry.npmjs.org/

# Public scoped package publishing.
access=public

# Enable npm provenance for GitHub Actions publishing.
# Package package.json repository.url values must match the GitHub repo exactly.
provenance=true

# Safer dependency/save behavior.
save-exact=true
fund=false

# Keep install-time audit noise out of CI package publishing.
audit=false

# Network reliability.
fetch-retries=10
fetch-retry-factor=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000

# Publishing should check the live registry, not stale cache.
prefer-offline=false
prefer-online=true