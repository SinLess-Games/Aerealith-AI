# Workspace-wide npm configuration for Aerealith AI packages.
# Keep this file safe for commit. Do not hardcode tokens here.
#
# Publishing auth should come from CI secrets or your user-level ~/.npmrc:
#   //registry.npmjs.org/:_authToken=${NPM_TOKEN}
#
# In GitHub Actions, use NODE_AUTH_TOKEN from secrets.NPM_TOKEN.

registry=https://registry.npmjs.org/
@aerealith-ai:registry=https://registry.npmjs.org/

# Publish defaults
access=public
provenance=true

# Dependency resolution / install behavior
save-exact=true
fund=false
audit=false

# Network reliability
fetch-retries=10
fetch-retry-factor=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
network-concurrency=4

# Avoid stale registry state during publish/CI.
prefer-offline=false
prefer-online=true