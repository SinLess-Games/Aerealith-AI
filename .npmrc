# Workspace-wide npm configuration for publishing packages under @helix-ai
# Never hardcode secrets here. Provide NPM_ACCESS_TOKEN as an env var (local shell
# export or CI secret) before running publish.

registry=https://registry.npmjs.org/
@aerealith-ai:registry=https://registry.npmjs.org/
always-auth=true

; Auth tokens should live in a user-specific file so CI/local shells can opt in
; without triggering warnings when the env var is missing.
; Copy .npmrc.local.example to .npmrc.local and keep your token there.
;include=.npmrc.local

fetch-retries=10
fetch-retry-factor=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
network-concurrency=4
prefer-offline=true